@page "/teacher/upload-exam-xml"
@attribute [Authorize(Roles = RoleNames.Teacher)]
@rendermode InteractiveServer

<PageTitle>Exam XML</PageTitle>

<h1 class="mb-2">Exam XML</h1>
<p class="text-secondary small mb-3">.xml only, 10&nbsp;MB max (same limit as the picker).</p>

<InputFile @key="_fileInputKey" OnChange="OnFileChanged" accept=".xml" class="form-control my-2" style="max-width: 28rem;" />

<button type="button" class="btn btn-primary mt-1" disabled="@(_file is null || _busy)" @onclick="UploadAsync">Send file</button>

@if (_successMessage is not null)
{
    <div class="alert alert-success mt-3" role="alert">@_successMessage</div>
}

@if (_errorMessage is not null)
{
    <div class="alert alert-danger mt-3" role="alert">@_errorMessage</div>
}

@inject HttpClient Http

@code {
    private int _fileInputKey;

    private IBrowserFile? _file;

    private bool _busy;

    private string? _successMessage;

    private string? _errorMessage;

    private void OnFileChanged(InputFileChangeEventArgs e)
    {
        _file = e.File;
        _successMessage = null;
        _errorMessage = null;
    }

    private async Task UploadAsync()
    {
        if (_file is null)
        {
            return;
        }

        _busy = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            Stream stream = _file.OpenReadStream(10_485_760);
            using var body = new MultipartFormDataContent();
            body.Add(new StreamContent(stream), "file", _file.Name);

            using HttpResponseMessage response = await Http.PostAsync("api/teacher/exams/batch-xml", body);
            string bodyText = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                _file = null;
                _fileInputKey++;
                _successMessage = "Saved the XML is processed and the exams graded.";
            }
            else
            {
                _errorMessage = HttpJsonErrorMessage.FromResponseBody(bodyText);
            }
        }
        finally
        {
            _busy = false;
        }
    }
}
