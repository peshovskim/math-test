@page "/teacher/exams"
@attribute [Authorize(Roles = RoleNames.Teacher)]
@rendermode InteractiveServer
@using System.Net.Http.Json
@using System.Text.Json
@using MathTest.Application.ExamResults

<PageTitle>Class exams</PageTitle>

<h1 class="mb-2">Class exams</h1>

<p class="text-secondary small mb-4">Exams you imported (by teacher id in XML), with student id and per-task correctness.</p>

@if (_loadError is not null)
{
    <div class="alert alert-danger" role="alert">@_loadError</div>
}
else if (_exams is null)
{
    <p class="text-muted">Loading…</p>
}
else if (_exams.Count == 0)
{
    <p class="text-muted">No exams are linked to your teacher account yet. Upload XML that uses your external id as the teacher root.</p>
}
else
{
    @foreach (TeacherExamListItem exam in _exams)
    {
        <section class="card mb-4 shadow-sm">
            <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
                <div>
                    <strong>Exam</strong>
                    <code class="ms-1">@exam.ExamExternalId</code>
                    <span class="text-muted small ms-2">Student <code>@exam.ExternalStudentId</code></span>
                </div>
                <div>
                    <span class="badge bg-secondary">Score: @exam.Score.ToString("0.#")%</span>
                </div>
            </div>
            <div class="card-body py-2">
                <p class="small text-muted mb-2">File: <span class="text-body">@exam.FileName</span></p>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Task</th>
                                <th scope="col">Expression</th>
                                <th scope="col" class="text-end">Student answer</th>
                                <th scope="col" class="text-end">Correct</th>
                                <th scope="col" class="text-center">Result</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (ExamTaskRow task in exam.Tasks)
                            {
                                <tr class="@(task.IsCorrect ? "table-success" : "table-danger")">
                                    <td>@(string.IsNullOrEmpty(task.ExternalId) ? "—" : task.ExternalId)</td>
                                    <td><code>@task.Expression</code></td>
                                    <td class="text-end">@task.StudentAnswer</td>
                                    <td class="text-end">@(task.CorrectAnswer?.ToString() ?? "—")</td>
                                    <td class="text-center fw-semibold">@(task.IsCorrect ? "Correct" : "Incorrect")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    }
}

@inject HttpClient Http

@code {
    private IReadOnlyList<TeacherExamListItem>? _exams;

    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            JsonSerializerOptions json = new(JsonSerializerDefaults.Web);
            _exams = await Http.GetFromJsonAsync<List<TeacherExamListItem>>("api/teacher/exams", json);
        }
        catch (Exception ex)
        {
            _loadError = $"Could not load exams ({ex.GetType().Name}).";
        }
    }
}
