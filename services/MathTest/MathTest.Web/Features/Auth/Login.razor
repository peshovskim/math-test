@page "/login"
@rendermode InteractiveServer

<PageTitle>Login</PageTitle>

<h1>Login</h1>

<EditForm Model="_model" OnValidSubmit="OnSubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <p>
        <label class="fw-bold">Email</label><br />
        <InputText type="email" @bind-Value="_model.Email" class="form-control w-75" />
        <ValidationMessage For="@(() => _model.Email)" />
    </p>
    <p>
        <label class="fw-bold">Password</label><br />
        <InputText type="password" @bind-Value="_model.Password" class="form-control w-75" />
        <ValidationMessage For="@(() => _model.Password)" />
    </p>

    <button type="submit" class="btn btn-primary" disabled="@_busy">Sign in</button>
</EditForm>

@if (_response is not null)
{
    <p class="mt-3">@_response.FirstName @_response.LastName / @_response.Email</p>
}

@if (_error is not null)
{
    <p class="text-danger mt-3">@_error</p>
}

@using System.Text.Json
@inject HttpClient Http

@code {
    private readonly LoginFormModel _model = new();

    private bool _busy;

    private string? _error;

    private LoginResponse? _response;

    private async Task OnSubmitAsync()
    {
        _busy = true;
        _error = null;
        _response = null;

        try
        {
            using HttpResponseMessage response = await Http.PostAsJsonAsync(
                "api/auth/login",
                new LoginUserRequest { Email = _model.Email.Trim(), Password = _model.Password });

            if (response.IsSuccessStatusCode)
            {
                _response = await response.Content.ReadFromJsonAsync<LoginResponse>(
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else
            {
                _error = await response.Content.ReadAsStringAsync();
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class LoginFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string Password { get; set; } = "";
    }
}
