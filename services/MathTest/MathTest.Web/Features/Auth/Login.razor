@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Login</PageTitle>

<h1>Login</h1>

@if (_error is not null)
{
    <p class="text-danger">@_error</p>
}

<form method="post" action="/api/auth/login">
    <input type="hidden" name="ReturnUrl" value="@_returnUrl" />
    <p>
        <label class="fw-bold">Email</label><br />
        <input name="Email" type="email" class="form-control w-75" required />
    </p>
    <p>
        <label class="fw-bold">Password</label><br />
        <input name="Password" type="password" class="form-control w-75" required />
    </p>
    <button type="submit" class="btn btn-primary">Sign in</button>
</form>

@inject NavigationManager Navigation

@code {
    private string _returnUrl = "/";

    private string? _error;

    protected override void OnInitialized()
    {
        Uri uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var q = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (q.TryGetValue("ReturnUrl", out Microsoft.Extensions.Primitives.StringValues r)
            && !Microsoft.Extensions.Primitives.StringValues.IsNullOrEmpty(r))
        {
            _returnUrl = Uri.UnescapeDataString(r.ToString());
        }

        if (!_returnUrl.StartsWith('/') || _returnUrl.StartsWith("//", StringComparison.Ordinal))
        {
            _returnUrl = "/";
        }

        if (q.ContainsKey("failed"))
        {
            _error = "Bad email or password.";
        }
    }
}
