@page "/register"
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Register</PageTitle>

<h1 class="mb-3">New account</h1>

<EditForm Model="_model" OnValidSubmit="OnSubmitAsync" class="mt-2" style="max-width: 26rem;">
    <DataAnnotationsValidator />
    <ValidationSummary />

    @if (_apiError is not null)
    {
        <div class="alert alert-danger py-2" role="alert">@_apiError</div>
    }

    <div class="mb-3">
        <label class="form-label">First name</label>
        <InputText @bind-Value="_model.FirstName" class="form-control" />
        <ValidationMessage For="@(() => _model.FirstName)" />
    </div>
    <div class="mb-3">
        <label class="form-label">Last name</label>
        <InputText @bind-Value="_model.LastName" class="form-control" />
        <ValidationMessage For="@(() => _model.LastName)" />
    </div>
    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText type="email" @bind-Value="_model.Email" class="form-control" autocomplete="email" />
        <ValidationMessage For="@(() => _model.Email)" />
    </div>
    <div class="mb-3">
        <label class="form-label">Password (8+ chars)</label>
        <InputText type="password" @bind-Value="_model.Password" class="form-control" autocomplete="new-password" />
        <ValidationMessage For="@(() => _model.Password)" />
    </div>
    <div class="mb-3">
        <label class="form-label">External ID</label>
        <InputText @bind-Value="_model.ExternalId" class="form-control" autocomplete="off" />
        <ValidationMessage For="@(() => _model.ExternalId)" />
        <div class="form-text">Pick from the seeded list — teachers <code>T-10001</code>…<code>T-10003</code>, students <code>S-20001</code>…<code>S-20005</code>.</div>
    </div>
    <div class="form-check mb-3">
        <InputCheckbox @bind-Value="_model.RegisterAsTeacher" class="form-check-input" id="reg-teacher" />
        <label class="form-check-label" for="reg-teacher">Teacher (uncheck = student)</label>
    </div>

    <button type="submit" class="btn btn-primary" disabled="@_busy">Create account</button>
</EditForm>

@inject HttpClient Http
@inject NavigationManager Navigation

@code {
    private readonly RegisterFormModel _model = new();

    private bool _busy;

    private string? _apiError;

    private async Task OnSubmitAsync()
    {
        _busy = true;
        _apiError = null;

        try
        {
            using HttpResponseMessage response = await Http.PostAsJsonAsync(
                "api/auth/register",
                new RegisterUserRequest
                {
                    FirstName = _model.FirstName.Trim(),
                    LastName = _model.LastName.Trim(),
                    Email = _model.Email.Trim(),
                    Password = _model.Password,
                    ExternalId = _model.ExternalId.Trim(),
                    RegisterAsTeacher = _model.RegisterAsTeacher,
                });

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/login?registered=1");
                return;
            }

            string body = await response.Content.ReadAsStringAsync();
            _apiError = HttpJsonErrorMessage.FromResponseBody(body);
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class RegisterFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string LastName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8)]
        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(256)]
        public string ExternalId { get; set; } = "";

        public bool RegisterAsTeacher { get; set; }
    }
}
