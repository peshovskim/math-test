@page "/register"
@attribute [AllowAnonymous]
@rendermode InteractiveServer

<PageTitle>Register</PageTitle>

<h1>Register</h1>

<EditForm Model="_model" OnValidSubmit="OnSubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <p>
        <label class="fw-bold">First name</label><br />
        <InputText @bind-Value="_model.FirstName" class="form-control w-75" />
        <ValidationMessage For="@(() => _model.FirstName)" />
    </p>
    <p>
        <label class="fw-bold">Last name</label><br />
        <InputText @bind-Value="_model.LastName" class="form-control w-75" />
        <ValidationMessage For="@(() => _model.LastName)" />
    </p>
    <p>
        <label class="fw-bold">Email</label><br />
        <InputText type="email" @bind-Value="_model.Email" class="form-control w-75" />
        <ValidationMessage For="@(() => _model.Email)" />
    </p>
    <p>
        <label class="fw-bold">Password</label><br />
        <InputText type="password" @bind-Value="_model.Password" class="form-control w-75" />
        <ValidationMessage For="@(() => _model.Password)" />
    </p>
    <p>
        <label class="fw-bold">Predefined external ID</label><br />
        <InputText @bind-Value="_model.ExternalId" class="form-control w-75" autocomplete="off" />
        <ValidationMessage For="@(() => _model.ExternalId)" />
        <span class="form-text">Teacher: T-10001 to T-10003. Student: S-20001 to S-20005.</span>
    </p>
    <p>
        <label>
            <InputCheckbox @bind-Value="_model.RegisterAsTeacher" /> teacher
        </label>
    </p>

    <button type="submit" class="btn btn-primary" disabled="@_busy">Register</button>
</EditForm>

@if (_message is not null)
{
    <p class="mt-3">@_message</p>
}

@inject HttpClient Http

@code {
    private readonly RegisterFormModel _model = new();

    private bool _busy;

    private string? _message;

    private async Task OnSubmitAsync()
    {
        _busy = true;
        _message = null;

        try
        {
            using HttpResponseMessage response = await Http.PostAsJsonAsync(
                "api/auth/register",
                new RegisterUserRequest
                {
                    FirstName = _model.FirstName.Trim(),
                    LastName = _model.LastName.Trim(),
                    Email = _model.Email.Trim(),
                    Password = _model.Password,
                    ExternalId = _model.ExternalId.Trim(),
                    RegisterAsTeacher = _model.RegisterAsTeacher,
                });

            _message = response.IsSuccessStatusCode
                ? "OK"
                : await response.Content.ReadAsStringAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class RegisterFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string FirstName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(100)]
        public string LastName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string Email { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8)]
        public string Password { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MaxLength(256)]
        public string ExternalId { get; set; } = "";

        public bool RegisterAsTeacher { get; set; }
    }
}
