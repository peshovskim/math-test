@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<h1 class="text-danger h3">That request blew up</h1>
<p class="text-secondary">Sorry — the server hit an exception. If you’re debugging, flip on Development and check the console / logs.</p>

@if (ShowRequestId)
{
    <p class="small">
        Correlation / request id: <code>@RequestId</code>
    </p>
}

<h2 class="h6 mt-4">Development</h2>
<p class="small">
    Set <code>ASPNETCORE_ENVIRONMENT=Development</code>, restart, and you’ll get stack traces here. Don’t ship prod like that.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
