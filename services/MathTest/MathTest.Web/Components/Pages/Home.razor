@page "/"

<PageTitle>Math Test</PageTitle>

<h1 class="mb-2">Math Test</h1>

<p class="mb-4" style="max-width: 36rem; line-height: 1.5;">
    Upload XML to get graded exams out.
</p>

<AuthorizeView>
    <Authorized>
        <p class="mb-0 text-secondary">Open Teacher or Student from the nav.</p>
    </Authorized>
    <NotAuthorized>
        <p class="mb-3">No session yet — register once, then sign in.</p>
        <a class="btn btn-primary me-2" href="login">Sign in</a>
        <a class="btn btn-outline-secondary" href="register">Register</a>
    </NotAuthorized>
</AuthorizeView>
